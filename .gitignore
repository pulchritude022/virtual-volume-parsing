# --- Secrets: never commit session cookies / credentials ---
secrets/*
!secrets/.gitkeep
!secrets/cookie.env.example

# --- Source images: copyright-restricted (NRS Crown copyright), large binaries ---
# Kept local by default. See PLAN.md (hosting decision: fully private, images not published).
data/**/images/
*.jpg
*.jpeg
*.png
!docs/**/*.png
!reference/**/*.png
# EXCEPTION: NRS permits displaying up to 20 images. data/<vol>/public-images/
# holds the ≤20 openings we publish (the first 20 transcribed). These are the
# ONLY manuscript images committed/published; everything else stays private.
!data/*/public-images/
!data/*/public-images/*.jpg
# Source-image bundles (Crown copyright) — never publish
data/**/*.zip
*.tif
*.tiff

# --- Python ---
__pycache__/
*.pyc
.venv/
venv/
*.egg-info/

# --- Node ---
node_modules/
dist/
.cache/

# --- OS / editor ---
.DS_Store
Thumbs.db
.vscode/
.idea/

# --- Generated site data ---
# Built by scripts/build_site.py from the transcriptions; the GitHub Pages
# workflow (.github/workflows/deploy-pages.yml) rebuilds it on every deploy, so
# the markdown is the single source of truth and the JSON is never committed.
# The hand-written front-end (docs/*.html, docs/assets/, docs/.nojekyll) stays tracked.
docs/data/

# --- Work artifacts ---
*.log
.env
data/**/.crops/       # transient reading crops emitted by preprocess.py
